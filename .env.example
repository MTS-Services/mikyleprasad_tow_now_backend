APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_SUPPORTED_LOCALES=en,es
# APP_LOCALE_HEADER=X-App-Locale
# APP_LOCALE_HEADER_ENABLED=true

# APP_ENABLED_CURRENCIES=USD,EUR,SAR
# APP_BASE_CURRENCY=USD
# APP_CURRENCY_HEADER=X-App-Currency
# APP_CURRENCY_HEADER_ENABLED=true
# CURRENCY_CACHE_TTL=120
# CURRENCY_FX_SYNC_ENABLED=false
# CURRENCY_FX_ALLOWED_HOSTS=api.frankfurter.app
# CURRENCY_FX_TIMEOUT=10

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use "pusher" with PUSHER_* below for realtime; "log" or "null" for local/CI without Pusher.
BROADCAST_CONNECTION=log

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Firebase Cloud Messaging (Kreait Laravel Firebase — credentials path relative to base_path()).
# FIREBASE_PROJECT must match the "project_id" inside the service account JSON.
# Use a Service Account key JSON ("type": "service_account") from Firebase Console → Project settings → Service accounts → Generate new private key.
# If the API returns invalid_grant / Invalid JWT Signature: the key file is wrong, revoked, or corrupted — generate a new key; run: php artisan firebase:verify-credentials
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
FIREBASE_PROJECT=app

FILESYSTEM_DISK=local
# Queue: FCM uses queue "notifications"; queued broadcasts (e.g. UserNotificationCreated) use "default".
# Run a worker that drains both, e.g. php artisan queue:work --queue=notifications,default
# Queue & cache use the database by default (no Redis).
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis (optional): uncomment when Redis is provisioned; then set QUEUE_CONNECTION=redis (and optionally CACHE_STORE=redis).
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Mailtrap (sandbox): use smtp + sandbox host; put real credentials only in local .env (never commit secrets).
# Port 2525: leave MAIL_SCHEME empty/null. For TLS on port 587, set MAIL_SCHEME=tls (see Mailtrap docs).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
# Any plausible address is fine for Mailtrap testing.
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Allow POST .../notifications/test-broadcast and .../notifications/test-push-token outside local (default false). Never enable in production.
# Also enables GET/POST /dev/fcm-test-push (Blade FCM tester). Never enable in production.
# NOTIFICATIONS_ALLOW_TEST_BROADCAST_ROUTE=false

# Auth API: "password" (default) or "otp" (passwordless).
# LOGIN_TYPE=password
# Comma-separated when using OTP login: email, phone, and/or username
# LOGIN_IDENTIFIERS=email
# When login uses both email+phone: email | phone | user_choice
# OTP_DELIVERY=email
# OTP_CODE_TTL_MINUTES=10
# OTP_CODE_LENGTH=6
# Minimum seconds between login OTP sends per identifier (429 + Retry-After when too soon). 0 disables.
# OTP_RESEND_SECONDS=60
# When false, unknown identifiers cannot request a login OTP (no implicit signup). Default true.
# OTP_ALLOW_REGISTRATION_ON_LOGIN=true

# Password reset (password login mode): email OTP, not links. See config/account.php
# PASSWORD_RESET_OTP_TTL_MINUTES=15
# PASSWORD_RESET_OTP_RESEND_SECONDS=60

# Laravel Passport — after deploy run migrations; if storage has no keys, run: php artisan passport:keys
# Optional: load keys from env instead of files (see https://laravel.com/docs/13.x/passport )
# PASSPORT_PRIVATE_KEY=
# PASSPORT_PUBLIC_KEY=


# Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

# Facebook
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/facebook/callback

GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

GOOGLE_TRANSLATE_PROJECT_ID=your_google_translate_project_id
GOOGLE_TRANSLATE_LOCATION=global
GOOGLE_TRANSLATE_CREDENTIALS=your_google_translate_credentials_path
# Optional:
# GOOGLE_TRANSLATE_V3_MODEL=projects/your-project/locations/global/models/general/nmt
# GOOGLE_TRANSLATE_V3_GLOSSARY=projects/your-project/locations/global/glossaries/your-glossary
TRANSLATION_SOURCE_LOCALE=en
TRANSLATION_AUTO_DETECT=true
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_STORE=database
TRANSLATION_CACHE_TTL=604800
TRANSLATION_QUEUE_ENABLED=true
TRANSLATION_QUEUE_CONNECTION=database
TRANSLATION_QUEUE_NAME=translations
GOOGLE_TRANSLATE_MODE=v2

MESSAGING_UNIQUE_TWO_PARTICIPANTS=true
MESSAGING_UNIQUE_GROUP_PARTICIPANTS=false

RIDE_REQUEST_EXPIRE_MINUTES=10